# ==============================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the values
# ==============================================

# GLOBAL CONFIGURATION
NODE_ENV=development
LOG_LEVEL=debug
TIMEZONE=Africa/Nairobi

# ----------------------------------------------
# 1. DATABASE (PostgreSQL)
# ----------------------------------------------
# Default credentials for local Docker setup
DB_HOST=postgres
DB_PORT=5432
DB_USER=saps_user
DB_PASSWORD=saps_password
DB_NAME=saps_db
DATABASE_URL=postgresql://saps_user:saps_password@postgres:5432/saps_db

# ----------------------------------------------
# 2. BACKEND (Node.js API Gateway)
# ----------------------------------------------
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# SECURITY & AUTH
JWT_SECRET=change_me_to_a_secure_random_string_in_production
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# ----------------------------------------------
# 3. M-PESA DARAJA API (Payments)
# ----------------------------------------------
# Get these from https://developer.safaricom.co.ke/
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/callback

# ----------------------------------------------
# 4. REDIS (Job Queue & Caching)
# ----------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------
# 5. AI & ML SERVICES (Python)
# ----------------------------------------------
# URL for the Python generic AI service
AI_SERVICE_URL=http://ai-services:8000
# URL for the Rasa Chatbot service
CHATBOT_SERVICE_URL=http://chatbot:5005

# ----------------------------------------------
# 6. EMAIL & NOTIFICATIONS
# ----------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=

# ----------------------------------------------
# 7. FRONTEND
# ----------------------------------------------
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000

